{
  "name": "kotlin-worksheet",
  "displayName": "Kotlin Worksheet",
  "description": "Evaluate Kotlin .worksheet.kts files and write inline results.",
  "version": "0.2.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "kotlin",
    "worksheet",
    "script",
    "repl",
    "education"
  ],
  "activationEvents": [
    "onLanguage:kotlin",
    "onCommand:kotlinWorksheet.run",
    "onCommand:kotlinWorksheet.rerun",
    "onCommand:kotlinWorksheet.clearResults",
    "onCommand:kotlinWorksheet.newWorksheet",
    "onCommand:kotlinWorksheet.toggleRunOnSave",
    "onCommand:kotlinWorksheet.toggleRenderMode",
    "workspaceContains:**/*.worksheet.kts"
  ],
  "main": "./out/extension.js",
  "extensionPack": [
    "fwcd.kotlin"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kotlinWorksheet.run",
        "title": "Kotlin Worksheet: Run"
      },
      {
        "command": "kotlinWorksheet.rerun",
        "title": "Kotlin Worksheet: Rerun"
      },
      {
        "command": "kotlinWorksheet.clearResults",
        "title": "Kotlin Worksheet: Clear Results"
      },
      {
        "command": "kotlinWorksheet.newWorksheet",
        "title": "Kotlin Worksheet: New Worksheet"
      },
      {
        "command": "kotlinWorksheet.toggleRunOnSave",
        "title": "Kotlin Worksheet: Toggle Run On Save"
      },
      {
        "command": "kotlinWorksheet.toggleRenderMode",
        "title": "Kotlin Worksheet: Toggle Render Mode"
      }
    ],
    "configuration": {
      "title": "Kotlin Worksheet",
      "properties": {
        "kotlinWorksheet.kotlinCommand": {
          "type": "string",
          "default": "kotlinc",
          "description": "Command used to run Kotlin scripts."
        },
        "kotlinWorksheet.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run worksheet files automatically when saved. Keep this off if VS Code Auto Save is enabled and worksheets are expensive."
        },
        "kotlinWorksheet.renderMode": {
          "type": "string",
          "enum": [
            "inlineComments",
            "decorations"
          ],
          "default": "inlineComments",
          "description": "How worksheet results are shown after execution."
        },
        "kotlinWorksheet.executionMode": {
          "type": "string",
          "enum": [
            "auto",
            "localKotlinc",
            "gradleClasspath"
          ],
          "default": "auto",
          "description": "How the worksheet execution classpath is resolved."
        },
        "kotlinWorksheet.timeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Maximum worksheet execution time in milliseconds."
        },
        "kotlinWorksheet.maxResultLength": {
          "type": "number",
          "default": 500,
          "minimum": 20,
          "description": "Maximum number of characters written for a single inline worksheet result."
        }
      }
    },
    "languages": [
      {
        "id": "kotlin",
        "aliases": [
          "Kotlin",
          "kotlin"
        ],
        "extensions": [
          ".kt",
          ".kts"
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kotlinWorksheet.run",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "kotlinWorksheet.run",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "1_modification"
        },
        {
          "command": "kotlinWorksheet.clearResults",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "1_modification"
        },
        {
          "command": "kotlinWorksheet.rerun",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "1_modification"
        },
        {
          "command": "kotlinWorksheet.toggleRunOnSave",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "1_modification"
        },
        {
          "command": "kotlinWorksheet.toggleRenderMode",
          "when": "resourceFilename =~ /\\.worksheet\\.kts$/",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "check": "pnpm lint && pnpm compile && pnpm test && pnpm package",
    "test": "vitest run",
    "vscode:prepublish": "pnpm compile",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/vscode": "1.100.0",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  }
}
